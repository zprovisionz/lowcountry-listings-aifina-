# ─────────────────────────────────────────────────────────────────────
# Lowcountry Listings AI — Example Environment Variables
# Copy to .env.local (frontend) and configure Supabase secrets (server).
# Do NOT commit real keys.
# ─────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# ── Supabase Edge Functions (server-side secrets) ────────────────────
# Set these in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# or via CLI: supabase secrets set NAME=value
OPENAI_API_KEY=
GOOGLE_MAPS_SERVER_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: fal.ai virtual staging
FAL_KEY=

# ── Stripe (server-side) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_PLUS_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

### Lowcountry Listings AI — example env file
### Copy to `.env.local` for local dev (client-side Vite vars only)

# ── Client (Vite) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_API_KEY=

### Optional: only needed if you run Supabase functions locally with `supabase functions serve`
### Put these in `./supabase/.env.local` (NOT in `.env.local`), or set them in Supabase Dashboard → Edge Functions → Secrets.

# ── Edge Functions secrets ──────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_MAPS_SERVER_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Edge Functions) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_PLUS_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ── fal.ai (optional, virtual staging) ──────────────────────────────
FAL_KEY=

